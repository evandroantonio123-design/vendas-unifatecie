# Chave da API da Anthropic (console.anthropic.com) - necessaria para o chat de IA e a importacao assistida
ANTHROPIC_API_KEY=

# Segredo usado para assinar o cookie de sessao do admin - troque por um valor aleatorio longo
SESSION_SECRET=troque-por-um-valor-aleatorio-longo

# Credenciais do admin (seedadas no banco na primeira vez que o servidor sobe)
ADMIN_EMAIL=admin@unifatecie.local
ADMIN_PASSWORD=troque-esta-senha

# Porta do servidor (a HostGator geralmente define isso automaticamente via cPanel)
PORT=3000
